rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default-deny Catch-All Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Validation Validators (Rule-Side Enforcers with Type & Size Checks)
    function isValidUserProfile(data) {
      return true; 
    }

    function isValidSavedItem(data) {
      return data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() <= 120
        && data.source is string && (data.source == 'manual' || data.source == 'directory' || data.source == 'ocr')
        && data.timestamp is string && data.timestamp.size() <= 100
        && (data.totalDucats is int || data.totalDucats is float) && data.totalDucats >= 0
        && (data.totalItems is int || data.totalItems is float) && data.totalItems >= 0
        && data.counts is map
        && (!('prices' in data) || data.prices is map);
    }

    function isValidListing(data) {
      return data.sellerUid == request.auth.uid
        && data.sellerIGN is string && data.sellerIGN.size() <= 100
        && data.normalizedSellerIGN is string && data.normalizedSellerIGN.size() <= 100
        && data.isSellerVerified == true
        && (!('sellerVerificationMethod' in data) || data.sellerVerificationMethod == null || (data.sellerVerificationMethod is string && (data.sellerVerificationMethod == 'forum' || data.sellerVerificationMethod == 'wfm_api' || data.sellerVerificationMethod == 'pasted_html')))
        && data.itemName is string && data.itemName.size() <= 200
        && (data.price is int || data.price is float) && data.price >= 0
        && (data.quantity is int || data.quantity is float) && data.quantity > 0
        && (data.type == 'WTS' || data.type == 'WTB')
        && (data.status == 'active' || data.status == 'sold' || data.status == 'cancelled');
    }

    // Rules for collections
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;

      allow create: if isOwner(userId) 
        && isValidUserProfile(incoming()) 
        && incoming().createdAt == request.time
        && incoming().lastLoginAt == request.time;

      allow update: if isOwner(userId) 
        && isValidUserProfile(incoming()) 
        && (incoming().lastLoginAt == existing().lastLoginAt || incoming().lastLoginAt == request.time)
        && incoming().createdAt == existing().createdAt
        && incoming().diff(existing()).affectedKeys().hasOnly(['lastLoginAt', 'displayName', 'photoURL', 'email', 'verification'])
        // Guard against client-side self-verification and privilege escalation
        && (
          !incoming().keys().hasAll(['verification'])
          // 🛡️ Guard 1: Only check equality if verification map actually exists in database
          || ('verification' in existing() && incoming().verification == existing().verification)
          || (
            // Client is initiating verification (transition to pending with null verifiedIGN)
            // Two-step verification: claimedIGN (in-game name) + profileSlug (URL slug for API lookup)
            incoming().verification.status == 'pending'
            && incoming().verification.verifiedIGN == null
            && incoming().verification.claimedIGN is string && incoming().verification.claimedIGN.size() > 0
            && incoming().verification.profileSlug is string && incoming().verification.profileSlug.size() > 0
            && incoming().verification.updatedAt is timestamp
            // 🛡️ Guard 2: Safe evaluation using short-circuit if map is completely missing
            && (!('verification' in existing()) || existing().verification.status != 'verified')
          )
          || (
            // Client is resetting/disconnecting verification back to unverified
            incoming().verification.status == 'unverified'
            && incoming().verification.claimedIGN == ''
            && incoming().verification.normalizedIGN == ''
            && incoming().verification.verifiedIGN == null
            && incoming().verification.token == null
            && incoming().verification.updatedAt is timestamp
          )
        );
      
      allow delete: if false;

      // Subcollection for cached Saved Items
      match /savedItems/{itemId} {
        allow get: if isOwner(userId) && isValidId(itemId);
        allow list: if isOwner(userId);

        allow create: if isOwner(userId) && isValidId(itemId)
          && isValidSavedItem(incoming())
          && incoming().createdAt == request.time;

        allow update: if isOwner(userId) && isValidId(itemId)
          && isValidSavedItem(incoming())
          && incoming().createdAt == existing().createdAt 
          && incoming().id == existing().id 
          && incoming().source == existing().source 
          && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'counts', 'totalDucats', 'totalItems', 'timestamp']);

        allow delete: if isOwner(userId) && isValidId(itemId);
      }
    }

    // Live listings market collection
    match /listings/{listingId} {
      allow get, list: if true;

      allow create: if isSignedIn() && isValidId(listingId)
        && isValidListing(incoming())
        && incoming().createdAt == request.time
        // 🛡️ Guard 3: Ensure listing queries don't crash if an unverified user's profile is blank
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && 'verification' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.verification.status == 'verified'
        && incoming().normalizedSellerIGN == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.verification.normalizedIGN;

      allow update: if isSignedIn() && isValidId(listingId)
        && existing().sellerUid == request.auth.uid
        && isValidListing(incoming())
        && incoming().sellerUid == existing().sellerUid
        && incoming().createdAt == existing().createdAt
        && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'price', 'quantity', 'itemName', 'type']);

      allow delete: if isSignedIn() && isValidId(listingId)
        && existing().sellerUid == request.auth.uid;
    }
  }
}
